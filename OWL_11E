# ---------- Wikipedia fallback (BULLETPROOF – ignores SSL errors for public data) ----------
def fetch_wikipedia_summary(query):
    """
    Return the first meaningful paragraph from Wikipedia.
    Uses search API if the direct title fails.
    Ignores SSL certificate errors because it's public data.
    """
    def make_request(url):
        try:
            # Create an SSL context that doesn't verify certificates
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            req = urllib.request.Request(url, headers={"User-Agent": "OWL_P20/1.0"})
            return urllib.request.urlopen(req, context=ctx, timeout=8)
        except:
            return None

    def _get_summary(title):
        resp = make_request(f"https://en.wikipedia.org/api/rest_v1/page/summary/{urllib.parse.quote(title)}")
        if resp:
            try:
                data = json.loads(resp.read().decode("utf-8"))
                if data.get("extract"):
                    return data["extract"]
            except:
                pass
        return None

    # 1. Try direct title
    summary = _get_summary(query)
    if summary:
        return summary

    # 2. Search Wikipedia for the correct title
    try:
        search_url = f"https://en.wikipedia.org/w/api.php?action=opensearch&search={urllib.parse.quote(query)}&limit=3&namespace=0&format=json"
        resp = make_request(search_url)
        if resp:
            data = json.loads(resp.read().decode("utf-8"))
            if data and len(data) > 1 and data[1]:
                for title in data[1]:
                    summary = _get_summary(title)
                    if summary:
                        return summary
    except:
        pass

    # 3. Final fallback: plain-text mobile page
    try:
        mobile_url = f"https://en.m.wikipedia.org/w/index.php?title={urllib.parse.quote(query)}&printable=yes"
        resp = make_request(mobile_url)
        if resp:
            html = resp.read().decode("utf-8")
            paragraphs = re.findall(r'<p>(.*?)</p>', html, re.DOTALL)
            for p in paragraphs:
                clean = re.sub(r'<[^>]+>', '', p).strip()
                if len(clean) > 50:
                    return clean
    except:
        pass

    return None

