def is_conversational(text):
    t = text.lower().strip()
    for phrase in CONVERSATIONAL_PHRASES:
        if phrase in t or FuzzyMatcher.similarity(phrase, t) > 0.8:
            return True
    if re.match(r'^(hello|hi|hey|namaste|pranam)\s+.*(kaise|dukhi|udaas|feel)', t):
        return True
    return False

