# ---------- SystemController ----------
class SystemController:
    def __init__(self):
        self.platform = sys.platform
        self.apps_dir = "/Applications"
        self.all_apps_cache = []
        self.cache_time = 0
        self.cache_duration = 60
    def _get_all_mac_apps(self):
        now = time.time()
        if now - self.cache_time < self.cache_duration and self.all_apps_cache:
            return self.all_apps_cache
        apps = set()
        try:
            r = subprocess.run(["mdfind","kMDItemContentType==com.apple.application-bundle"],
                               capture_output=True, text=True, timeout=15)
            if r.returncode == 0:
                for line in r.stdout.strip().splitlines():
                    if line.strip() and line.endswith(".app"): apps.add(line.strip())
        except: pass
        search_paths = ["/Applications","/System/Applications","/System/Library/CoreServices",
                        os.path.expanduser("~/Applications")]
        for path in search_paths:
            if os.path.exists(path):
                try:
                    r = subprocess.run(["find",path,"-name","*.app","-maxdepth","3"],
                                       capture_output=True, text=True, timeout=10)
                    if r.returncode == 0:
                        for line in r.stdout.strip().splitlines():
                            if line.strip(): apps.add(line.strip())
                except: pass
        self.all_apps_cache = list(apps)
        self.cache_time = now
        return self.all_apps_cache
    def _extract_app_name(self, path):
        return os.path.basename(path).replace(".app","").strip()
    def search_macos_app(self, app_name):
        an = FuzzyMatcher.normalize_text(app_name)
        all_apps = self._get_all_mac_apps()
        best_match, best_score = None, 0
        for p in all_apps:
            base = self._extract_app_name(p)
            score = FuzzyMatcher.similarity(an, base)
            score2 = FuzzyMatcher.similarity(an.replace(" ",""), base.replace(" ",""))
            score = max(score, score2)
            fw = an.split()[0] if an.split() else an
            fwb = base.split()[0] if base.split() else base
            score3 = FuzzyMatcher.similarity(fw, fwb) * 0.9
            score = max(score, score3)
            if score > best_score:
                best_score = score
                best_match = p
        if best_score >= 0.8 and ' ' not in an:
            return best_match
        return None
    def get_info(self):
        info = {"platform": self.platform, "timestamp": datetime.datetime.now().isoformat(),
                "python": sys.version.split()[0], "network": "Unknown"}
        try:
            if self.platform in ["darwin","linux"]:
                subprocess.check_output(["ping","-c","1","google.com"], timeout=5)
                info["network"] = "Connected"
            elif self.platform == "win32":
                subprocess.check_output(["ping","-n","1","google.com"], timeout=5)
                info["network"] = "Connected"
        except: pass
        return info
    def open_app(self, name_or_path):
        try:
            if self.platform == "darwin":
                if os.path.exists(name_or_path) and name_or_path.endswith(".app"):
                    subprocess.Popen(["open", name_or_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                    return "Opened " + os.path.basename(name_or_path)
                else:
                    subprocess.Popen(["open","-a", name_or_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                    return "Opened " + name_or_path
            elif self.platform == "linux":
                subprocess.Popen([name_or_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return "Opened " + name_or_path
            elif self.platform == "win32":
                subprocess.Popen(["start", name_or_path], shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return "Opened " + name_or_path
        except Exception as e:
            return "Could not open " + name_or_path + ": " + str(e)
    def open_url(self, url):
        try:
            if not url.startswith(("http://","https://")): url = "https://" + url
            webbrowser.open(url)
            return "Opened " + url
        except Exception as e: return "Failed to open " + url + ": " + str(e)
    def play_youtube(self, query):
        url = "https://www.youtube.com/results?search_query=" + urllib.parse.quote(query)
        self.open_url(url)
        return "YouTube search: " + query
    def open_maps(self, location):
        if self.platform == "darwin":
            url = "https://maps.apple.com/?q=" + urllib.parse.quote(location)
        else:
            url = "https://www.google.com/maps/search/" + urllib.parse.quote(location)
        self.open_url(url)
        return "Maps: " + location
    def create_file(self, filename, content=""):
        try:
            with open(filename, "w", encoding="utf-8") as f: f.write(content)
            return "Created: " + filename
        except Exception as e: return "Error: " + str(e)
    def read_file(self, filename):
        try:
            with open(filename, "r", encoding="utf-8") as f: return f.read()
        except Exception as e: return "Error reading: " + str(e)

