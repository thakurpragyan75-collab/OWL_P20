    def expand_patterns(base_patterns):
        expanded = set()
        for p in base_patterns:
            expanded.add(p)
            expanded.add(p.replace('a','aa'))
            expanded.add(p.replace('e','ee'))
            if len(p) > 2: expanded.add(p[0] + p[2] + p[1] + p[3:])
