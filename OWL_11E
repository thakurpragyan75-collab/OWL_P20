class AudioRecorder:
    def __init__(self):
        self.recording = False
        self.filename = None
        self.stream = None
        self.fs = 44100
        self.frames = []
    def start(self, filename=None):
        if not RECORDING_AVAILABLE: return False, "sounddevice not installed"
        if self.recording: return False, "Already recording"
        self.filename = filename or os.path.join(os.path.expanduser("~"), "Desktop", "OWL_DATA", "recordings", f"recording_{int(time.time())}.wav")
        os.makedirs(os.path.dirname(self.filename), exist_ok=True)
        self.frames = []
        self.recording = True
        def callback(indata, frames, time, status): self.frames.append(indata.copy())
        self.stream = sd.InputStream(samplerate=self.fs, channels=1, callback=callback)
        self.stream.start()
        return True, f"Recording started: {self.filename}"
    def stop(self):
        if not self.recording: return False, "Not recording"
        self.stream.stop()
        self.stream.close()
        self.recording = False
        import numpy as np
        data = np.concatenate(self.frames, axis=0)
        sf.write(self.filename, data, self.fs)
        return True, f"Recording saved: {self.filename}"

