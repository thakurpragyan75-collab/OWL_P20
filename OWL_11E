    def _handle_calculate(self, cmd):
        if "handshake" in cmd.lower():
            nums = re.findall(r"\d+", cmd)
            if nums:
                n = int(nums[0])
                if n >= 2:
                    res = n * (n - 1) // 2
                    return f"{n} people = {res} handshakes!\nFormula: C(n,2) = n*(n-1)/2"
        if "irrational" in cmd.lower() and ("sqrt" in cmd.lower() or "square root" in cmd.lower()):
            return "Proof that root 2 is irrational:\n1. Assume root 2 = p/q\n2. Square: 2 = p2/q2 -> p2 = 2q2\n3. p2 even -> p even\n4. p = 2k -> 4k2 = 2q2 -> q2 = 2k2\n5. q2 even -> q even\n6. Contradiction: both p,q even!\n7. Therefore root 2 is IRRATIONAL"
        if "prime" in cmd.lower():
            nums = re.findall(r"\d+", cmd)
            if nums:
                n = int(nums[0])
                return f"{n} is {'PRIME' if n>=2 and all(n%i for i in range(2,int(n**0.5)+1)) else 'NOT PRIME'}!"
        if "factorial" in cmd.lower() or "!" in cmd:
            nums = re.findall(r"\d+", cmd)
            if nums and int(nums[0]) <= 20: return f"{int(nums[0])}! = {math.factorial(int(nums[0]))}"
        expr = re.sub(r"\b(calculate|calc|hisab|solve|compute|math|gin|count|karo|jodo|ghatao|guna|bhag|plus|minus|times|divided|add|subtract|multiply|divide|sum|total|jod|ghata|gun|bhag|jodo|ghatao|guna karo|bhag karo|jod do|ghata do|guna do|bhag do|jod karo|ghata karo)\b", "", cmd, flags=re.IGNORECASE).strip()
        math_expr = expr.replace("^","**").replace("plus","+").replace("minus","-").replace("times","*").replace("divided","/")
        m = re.search(r"[\d\+\-\*/\(\)\.\^\s]+", math_expr)
        if m:
            try:
                safe = {"__builtins__": None}
                safe.update({k: getattr(math,k) for k in dir(math) if not k.startswith("_")})
                return "Result: " + str(eval(m.group(), safe))
            except: pass
        return "I couldn't calculate that. Try: calculate 25+50, handshake 7, factorial 5, prime 17"

