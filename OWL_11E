class FuzzyMatcher:
    @staticmethod
    def similarity(a, b):
        if not a or not b: return 0.0
        a, b = a.lower().strip(), b.lower().strip()
        if a == b: return 1.0
        if a in b or b in a: return 0.85
        seq = difflib.SequenceMatcher(None, a, b)
        ratio = seq.ratio()
        prefix = 0
        for i in range(min(len(a), len(b))):
            if a[i] == b[i]: prefix += 1
            else: break
        jaro_boost = prefix * 0.1 / max(len(a), len(b)) if max(len(a), len(b)) > 0 else 0
        return min(1.0, ratio + jaro_boost)

