class WebIntelligence:
    def __init__(self, brain): self.brain = brain
    def search(self, query, num=3):
        results = []
        try:
            headers = {"User-Agent": "Mozilla/5.0"}
            ddg_url = "https://html.duckduckgo.com/html/?q=" + urllib.parse.quote(query)
            req = urllib.request.Request(ddg_url, headers=headers)
            with urllib.request.urlopen(req, timeout=10) as resp:
                html = resp.read().decode("utf-8")
            link_pat = r'<a rel="nofollow" class="result__a" href="([^"]+)">([^<]+)</a>'
            matches = re.findall(link_pat, html)
            for url, title in matches[:num]:
                results.append({"url": url, "title": title.strip(), "source": "DuckDuckGo"})
        except:
            pass
        results.append({"url": "https://www.google.com/search?q=" + urllib.parse.quote(query),
                       "title": f"Search Google for '{query}'", "source": "Google"})
        return results

