# ---------- KnowledgeGraph ----------
class KnowledgeGraph:
    def __init__(self, filepath=os.path.join(os.path.expanduser("~"), "Desktop", "OWL_DATA", "brain_knowledge.json")):
        self.filepath = filepath
        self.graph = defaultdict(dict)
        self.load()
        self.add_default_facts()
    def load(self):
        if os.path.exists(self.filepath):
            try:
                with open(self.filepath, "r", encoding="utf-8") as f:
                    self.graph = defaultdict(dict, json.load(f))
            except:
                self.graph = defaultdict(dict)
    def save(self):
        os.makedirs(os.path.dirname(self.filepath), exist_ok=True)
        with open(self.filepath, "w", encoding="utf-8") as f:
            json.dump(dict(self.graph), f, indent=2, ensure_ascii=False)
    def add_fact(self, subject, predicate, obj, confidence=1.0):
        if subject not in self.graph: self.graph[subject] = {}
        self.graph[subject][predicate] = {
            "object": obj, "confidence": confidence,
            "timestamp": datetime.datetime.now().isoformat(), "access_count": 0
        }
        self.save()
    def add_default_facts(self):
        defaults = {
            "knowledge": "Knowledge is the facts, information, and skills acquired through experience or education.",
            "india": "India is a country in South Asia, the world's largest democracy.",
            "python": "Python is a high-level, interpreted programming language known for its readability.",
            "owl_p20": f"I am {APP_NAME}, the Absolute Self‑Living Superintelligence built by MASTER PRAGYAN.",
            "water": "Water is a transparent, tasteless, odorless liquid (H2O) essential for life.",
            "power": "Power, in physics, is the amount of energy transferred or converted per unit time.",
        }
        for subj, obj in defaults.items():
            if subj not in self.graph:
                self.add_fact(subj, "is", obj)
    def query(self, subject):
        results = {}
        subj = subject.lower().strip()
        if subject in self.graph: results[subject] = self.graph[subject]
        for key in self.graph.keys():
            if FuzzyMatcher.similarity(subj, key.lower()) > 0.9:
                if key not in results: results[key] = self.graph[key]
        return results

