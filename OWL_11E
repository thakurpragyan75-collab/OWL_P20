                tree = ET.parse(resp)
                root = tree.getroot()
                items = []
                for item in root.iter('item'):
                    title = item.find('title').text
                    link = item.find('link').text
                    items.append({"title": title, "link": link})
                    if len(items) >= num:
                        break
                return items
            except:
                return None
        headlines = try_fetch("https://news.google.com/rss?hl=en-IN&gl=IN&ceid=IN:en")
